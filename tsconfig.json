{
  "compilerOptions": {
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "target": "ESNext",
    "module": "commonjs",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "./dist/",
    "alwaysStrict": true,
    "strict": true
  },
  "lib": [ "esnext", "dom" ],
  "include": [
      "src/**/*"
  ],
  "exclude": [
    "**/node_modules",
    "**/.*/",
    "scripts/",
    "dist/",
    "wiki/",
    "coverage/",
    "doc/"
  ]
}
